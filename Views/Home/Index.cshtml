@{
    ViewData["Title"] = "Home Page";
}


<div class="hero-section text-center py-5 mb-5" style="background: linear-gradient(135deg, #FF9933 0%, #8B0000 100%); color: white; border-radius: 0 0 30px 30px;">
    <div class="container">
        <h1 class="display-4 fw-bold">🌟 स्वागत है | Welcome to Eventease</h1>
        <p class="lead">Your all-in-one booking system for events and venues</p>
        <a href="/Bookings" class="btn btn-warning btn-lg mt-3 px-4 py-2 fw-semibold text-dark">Get Started →</a>
    </div>
</div>


<div class="container mb-5">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4" style="background-color: #FFF8E7; border-top: 5px solid #FF9933;">
                <div class="card-body p-4">
                    <div class="mb-3" style="font-size: 3rem;">📅</div>
                    <h5 class="card-title" style="color: #8B0000;">Manage Events</h5>
                    <p class="card-text text-muted">Create, edit, and organize all your events in one place.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4" style="background-color: #FFF8E7; border-top: 5px solid #138808;">
                <div class="card-body p-4">
                    <div class="mb-3" style="font-size: 3rem;">📍</div>
                    <h5 class="card-title" style="color: #8B0000;">Browse Venues</h5>
                    <p class="card-text text-muted">Discover and book the perfect venue for any occasion.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4" style="background-color: #FFF8E7; border-top: 5px solid #FF9933;">
                <div class="card-body p-4">
                    <div class="mb-3" style="font-size: 3rem;">✅</div>
                    <h5 class="card-title" style="color: #8B0000;">Easy Bookings</h5>
                    <p class="card-text text-muted">Track and manage all your bookings effortlessly.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Call to Action with rich maroon background -->
<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center p-5 rounded-4 shadow-sm" style="background-color: #8B0000; color: #FFD700;">
            <h3>✨ तैयार हैं? Ready to get started? ✨</h3>
            <p class="mb-4">Create a new booking or explore available events and venues.</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/Bookings/Create" class="btn btn-warning fw-semibold" style="background-color: #FF9933; border: none; color: #8B0000;">+ New Booking</a>
                <a href="/Events" class="btn btn-outline-light" style="border-color: #FFD700; color: #FFD700;">View Events</a>
            </div>
        </div>
    </div>
</div>