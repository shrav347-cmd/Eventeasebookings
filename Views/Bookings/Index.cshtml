@model IEnumerable<EventeaseBookingSystem.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1 class="mb-3">Bookings</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<p>
    <a class="btn btn-primary" asp-action="Create">
        + Create New Booking
    </a>
</p>

<form method="get" asp-action="Index" class="mb-3">
    <div class="input-group">
        <input type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Search by Booking ID, Event, Venue, or Customer..." />

        <button type="submit" class="btn btn-primary">
            Search
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Clear
        </a>
    </div>
</form>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Booking ID</th>
            <th>Venue</th>
            <th>Event</th>
            <th>Customer</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th style="width: 200px;">Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted">
                    No bookings found.
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.BookingID</td>
                    <td>@item.Venue?.VenueName</td>
                    <td>@item.Event?.EventName</td>
                    <td>@item.CustomerName</td>

                    <td>
                        @item.StartDate.ToString("dd MMM yyyy HH:mm")
                    </td>

                    <td>
                        @item.EndDate.ToString("dd MMM yyyy HH:mm")
                    </td>

                    <td>
                        <a class="btn btn-warning btn-sm"
                               asp-action="Edit"
                               asp-route-id="@item.BookingID">
                            Edit
                        </a>

                        <a class="btn btn-info btn-sm"
                               asp-action="Details"
                               asp-route-id="@item.BookingID">
                            Details
                        </a>

                        <a class="btn btn-danger btn-sm"
                               asp-action="Delete"
                               asp-route-id="@item.BookingID">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>