@model IEnumerable<EventeaseBookingSystem.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<h1>Venues</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New Venue</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Venue Name</th>
            <th>Location</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.VenueName</td>
                <td>@item.Location</td>
                <td>
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.VenueID">Edit</a>
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.VenueID">Details</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.VenueID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>