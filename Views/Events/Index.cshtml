@model IEnumerable<EventeaseBookingSystem.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<h1>Events</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<p>
    <a class="btn btn-primary" asp-action="Create">Create New Event</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Event Name</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Venue</th>
            <th>Image</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    No events found.
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EventName</td>
                    <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                    <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                    <td>@item.Venue?.VenueName</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageURL))
                        {
                            <img src="@item.ImageURL" width="100" alt="@item.EventName" />
                        }
                        else
                        {
                            <span class="text-muted">No image</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.EventID">Edit</a>
                        <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.EventID">Details</a>
                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.EventID">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>