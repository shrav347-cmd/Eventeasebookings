@model IEnumerable<EventeaseBookingSystem.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<h1>Events</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New Event</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Event Name</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Venue</th>
            <th>Image</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EventName</td>
                <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                <td>@item.Venue?.VenueName</td>
                <td>
                    <img src="@item.ImageURL" width="100" />
                </td>
                <td>
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.EventID">Edit</a>
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.EventID">Details</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.EventID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>